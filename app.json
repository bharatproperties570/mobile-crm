{
  "expo": {
    "name": "Bharat Properties CRM",
    "slug": "bharat-properties-crm-mobile",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bharatproperties",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bharatproperties.crm",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.bharatproperties.crm",
      "permissions": [
        "READ_CALL_LOG",
        "READ_PHONE_STATE",
        "READ_CONTACTS",
        "SYSTEM_ALERT_WINDOW",
        "FOREGROUND_SERVICE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#1E40AF"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-calendar",
        {
          "calendarPermission": "Allow Bharat Properties to sync with your calendar."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8a273a2e-193d-4d23-86b9-3e41ba6c398a"
      }
    },
    "owner": "bharatproperties"
  }
}
